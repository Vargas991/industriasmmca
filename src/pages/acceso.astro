---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { buildPageSeo } from "@/lib/seo/metadata";
---
<BaseLayout
  seo={buildPageSeo({
    title: "Acceso CMS | Industrias MM",
    description: "Completa tu acceso al gestor de contenidos de Industrias MM.",
    canonical: "/acceso",
    noindex: true,
  })}
>
  <section class="section-padding">
    <div class="container">
      <div class="auth-shell flow">
        <img class="auth-logo" src="/images/brand/logo.webp" alt="Industrias MM" />
        <p class="eyebrow">CMS</p>
        <h1 data-identity-title>Define una nueva contrasena</h1>
        <p>Completa este paso para terminar el acceso al panel y entrar a administrar el contenido.</p>
        <form class="contact-form flow" data-identity-form>
          <label class="field" for="password">
            <span>Nueva contrasena</span>
            <input id="password" name="password" type="password" minlength="8" required />
          </label>
          <label class="field" for="passwordConfirm">
            <span>Confirmar contrasena</span>
            <input id="passwordConfirm" name="passwordConfirm" type="password" minlength="8" required />
          </label>
          <button class="button button--primary" data-identity-submit type="submit">Guardar nueva contrasena</button>
        </form>
        <p class="identity-message" data-identity-message data-tone="info"></p>
      </div>
    </div>
  </section>
  <script>
    import "@/scripts/netlify-identity-access";
  </script>
</BaseLayout>
