---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { isAdminAuthenticated } from "@/lib/admin/auth";
import { getAllProductCategories } from "@/lib/content/productCategories";
import { getAllProducts } from "@/lib/content/products";
import { isCloudinaryConfigured } from "@/lib/cloudinary";

export const prerender = false;

const authenticated = isAdminAuthenticated(Astro.cookies);
const [products, categories] = authenticated
  ? await Promise.all([getAllProducts(), getAllProductCategories()])
  : [[], []];

const payload = {
  products,
  categories,
  cloudinaryConfigured: isCloudinaryConfigured(),
};
---
<AdminLayout title="Admin | Productos" section="products" authenticated={authenticated}>
  <section class="hero-strip">
    <div class="hero-panel">
      <p class="eyebrow-badge">Productos</p>
      <h1 class="hero-title">Gestión de productos</h1>
      <p class="hero-copy">
        Aquí ya no todo está acumulado con el resto del panel. Este módulo se enfoca solo en productos, categorías relacionadas, imágenes y
        contenido comercial.
      </p>
      <div class="hero-actions">
        <button class="button button--primary" id="new-product-button" type="button">Nuevo producto</button>
        <a class="button button--secondary" href="/admin/categorias">Ver categorías</a>
        <a class="button button--secondary" href="/admin/medios">Abrir medios</a>
        <button class="button button--secondary" type="button" data-admin-logout>Cerrar sesión</button>
      </div>
    </div>

    <div class="hero-side">
      <div class="spotlight-card">
        <p>Mejora incluida</p>
        <strong>La imagen principal ya se puede subir y previsualizar desde esta misma página</strong>
      </div>
    </div>
  </section>

  <section class="panel-card">
    <div class="inner">
      <div class="section-heading">
        <div>
          <h2>Listado y editor</h2>
          <p class="muted">Selecciona un producto a la izquierda o crea uno nuevo desde cero.</p>
          <button class="button button--secondary" id="back-to-list" type="button" style="display:none;margin-top:1rem;">← Volver al listado</button>
        </div>
      </div>

      <div class="workspace-grid" id="workspace-grid">
        <aside class="subgrid" id="product-list-aside">
          <div class="section-box">
            <label for="product-search">Buscar producto</label>
            <input class="search-bar" id="product-search" type="search" placeholder="Nombre, slug o categoría" />
            <p class="muted" id="product-count-note" style="margin: 0.75rem 0 0;"></p>
          </div>

          <div class="list-shell">
            <div class="list-head">
              <span>Imagen</span>
              <span>Producto</span>
              <span>Categoría</span>
              <span>Precio</span>
              <span>Estado</span>
            </div>
            <div class="record-list" id="product-list"></div>
          </div>
        </aside>

        <section class="subgrid" id="product-detail-section">
          <div class="section-heading">
            <div>
              <h3 id="product-editor-title">Nuevo producto</h3>
              <p class="muted">Formulario modular con subida de medios integrada.</p>
            </div>
          </div>
          <p class="feedback muted" id="product-feedback"></p>

          <form class="stack editor-shell" id="product-form">
            <input id="product-id" name="productId" type="hidden" />

            <div class="editor-tabs" data-editor-tabs>
              <a class="editor-tab is-active" href="#product-general">Información</a>
              <a class="editor-tab" href="#product-images">Imágenes</a>
              <a class="editor-tab" href="#product-tech">Técnica</a>
              <a class="editor-tab" href="#product-body">Contenido</a>
              <a class="editor-tab" href="#product-seo">SEO</a>
            </div>

            <div class="editor-sections">
              <section class="section-box" id="product-general">
                <h3>Información general</h3>
                <div class="field-grid">
                  <div class="field"><label for="title">Nombre del producto</label><input id="title" name="title" required /></div>
                  <div class="field"><label for="slug">Slug</label><input id="slug" name="slug" placeholder="Se genera si lo dejas vacío" /></div>
                  <div class="field"><label for="category">Categoría</label><select id="category" name="category" required></select></div>
                  <div class="field"><label for="status">Estado</label><select id="status" name="status"><option value="draft">Borrador</option><option value="published">Publicado</option></select></div>
                  <div class="field"><label for="price">Precio</label><input id="price" name="price" type="number" step="0.01" min="0" /></div>
                  <div class="field"><label for="show_price"><input id="show_price" name="show_price" type="checkbox" /> Mostrar precio</label></div>
                  <div class="field field--full"><label for="description">Descripción corta</label><textarea id="description" name="description" required></textarea></div>
                  <div class="field field--full"><label for="excerpt">Descripción principal / extracto</label><textarea id="excerpt" name="excerpt" required></textarea></div>
                </div>
              </section>

              <section class="section-box" id="product-images">
                <h3>Imágenes y archivos</h3>
                <div class="field-grid">
                  <div class="field field--full">
                    <label for="coverImage">Imagen principal</label>
                    <input id="coverImage" name="coverImage" readonly />
                  </div>
                  <div class="field field--full">
                    <label for="coverAlt">Texto ALT de portada</label>
                    <input id="coverAlt" name="coverAlt" required />
                  </div>
                  <div class="field">
                    <label for="cover-file">Subir portada</label>
                    <input id="cover-file" type="file" accept="image/*" />
                  </div>
                  <div class="field">
                    <label>&nbsp;</label>
                    <button class="button button--secondary" id="upload-cover-button" type="button">Subir portada</button>
                    <button class="button button--secondary" id="select-cover-button" type="button" style="margin-left: 0.5rem;">Seleccionar existente</button>
                  </div>
                  <div class="field field--full">
                    <div class="preview-media" id="cover-preview"></div>
                  </div>
                  <div class="field field--full">
                    <label for="gallery">Galería</label>
                    <textarea id="gallery" name="gallery" placeholder="Una URL por línea" style="display:none;"></textarea>
                  </div>
                  <div class="field">
                    <label for="gallery-files">Subir a galería</label>
                    <input id="gallery-files" type="file" accept="image/*" multiple />
                  </div>
                  <div class="field">
                    <label>&nbsp;</label>
                    <button class="button button--secondary" id="upload-gallery-button" type="button">Agregar a galería</button>
                    <button class="button button--secondary" id="select-gallery-button" type="button" style="margin-left: 0.5rem;">Seleccionar existentes</button>
                  </div>
                  <div class="field field--full">
                    <div class="gallery-grid" id="gallery-preview"></div>
                  </div>
                  <div class="field">
                    <label for="specSheet">Ficha técnica PDF</label>
                    <input id="specSheet" name="specSheet" readonly />
                  </div>
                  <div class="field">
                    <label for="spec-sheet-file">Subir ficha técnica</label>
                    <input id="spec-sheet-file" type="file" accept=".pdf,application/pdf" />
                  </div>
                  <div class="field">
                    <label>&nbsp;</label>
                    <button class="button button--secondary" id="upload-sheet-button" type="button">Subir ficha</button>
                  </div>
                  <div class="field">
                    <label><input id="featured" name="featured" type="checkbox" /> Destacar en listados e inicio</label>
                  </div>
                </div>
              </section>

              <section class="section-box" id="product-tech">
                <h3>Características técnicas</h3>
                <div class="field-grid">
                  <div class="field field--full"><label for="measurements">Medidas o variantes</label><textarea id="measurements" name="measurements" placeholder="Formato por línea: Modelo A | 90 | 200 | 40 | 180 | 1200 | kg"></textarea></div>
                  <div class="field field--full"><label for="specs">Atributos técnicos</label><textarea id="specs" name="specs" placeholder="Formato: Material: Acero"></textarea></div>
                  <div class="field field--full"><label for="benefits">Beneficios destacados</label><textarea id="benefits" name="benefits" placeholder="Un beneficio por línea"></textarea></div>
                </div>
              </section>

              <section class="section-box" id="product-body">
                <h3>Contenido comercial</h3>
                <div class="field">
                  <label for="body">Contenido del producto</label>
                  <textarea id="body" name="body" style="min-height: 18rem;" placeholder="Markdown del producto"></textarea>
                </div>
              </section>

              <section class="section-box" id="product-seo">
                <h3>SEO y publicación</h3>
                <div class="field-grid">
                  <div class="field"><label for="seoTitle">Título SEO</label><input id="seoTitle" name="seoTitle" required /></div>
                  <div class="field"><label for="seoCanonical">Canonical</label><input id="seoCanonical" name="seoCanonical" /></div>
                  <div class="field field--full"><label for="seoDescription">Descripción SEO</label><textarea id="seoDescription" name="seoDescription" required></textarea></div>
                  <div class="field"><label for="seoImage">Imagen social</label><input id="seoImage" name="seoImage" readonly /></div>
                  <div class="field"><label for="seo-image-file">Subir imagen SEO</label><input id="seo-image-file" type="file" accept="image/*" /></div>
                  <div class="field"><label>&nbsp;</label><button class="button button--secondary" id="upload-seo-button" type="button">Subir imagen SEO</button><button class="button button--secondary" id="select-seo-button" type="button" style="margin-left: 0.5rem;">Seleccionar existente</button></div>
                </div>
              </section>
            </div>

            <section class="preview-card">
              <div class="preview-media" id="product-preview-media"></div>
              <div>
                <strong id="product-preview-title">Nuevo producto</strong>
                <p class="muted" id="product-preview-copy" style="margin: 0.35rem 0 0;">Aquí verás una síntesis del registro activo.</p>
              </div>
              <div class="preview-list">
                <div class="preview-line"><span>Categoría</span><span id="product-preview-category">-</span></div>
                <div class="preview-line"><span>Estado</span><span id="product-preview-status">Borrador</span></div>
                <div class="preview-line"><span>Ficha técnica</span><span id="product-preview-sheet">No</span></div>
              </div>
            </section>

            <div class="button-row">
              <button class="button button--primary" id="save-product-button" type="submit">Guardar producto</button>
              <button class="button button--secondary" id="reset-product-button" type="button">Restaurar editor</button>
              <button class="button button--danger" id="delete-product-button" type="button">Eliminar producto</button>
            </div>
          </form>
        </section>
      </div>
    </div>
  </section>

  <!-- Modal para seleccionar imágenes existentes -->
  <div id="image-selector-modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); z-index: 1000; align-items: center; justify-content: center;">
    <div style="background: white; border-radius: 1rem; padding: 2rem; width: 95%; max-height: 95vh; overflow: auto; position: relative;">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
        <h3 style="margin: 0;">Seleccionar imagen existente</h3>
        <button id="close-image-selector" style="background: none; border: none; font-size: 1.5rem; cursor: pointer;">&times;</button>
      </div>
      <div id="image-selector-feedback" style="margin-bottom: 0.8rem; color: #666;"></div>
      <div id="image-selector-breadcrumbs" style="margin-bottom: 1rem; font-size: 0.95rem; color: #333;"></div>
      <div id="image-selector-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 1rem; max-height: 70vh; overflow: auto;">
        <!-- Las imágenes se cargarán aquí -->
      </div>
      <div style="margin-top: 1rem; display: flex; justify-content: space-between; align-items: center;">
        <div>
          <input id="upload-to-folder-file" type="file" accept="image/*" multiple style="display: none;" />
          <button id="upload-to-folder-button" class="button button--secondary" type="button">Subir aquí</button>
        </div>
        <button id="cancel-image-selector" class="button button--secondary">Cancelar</button>
      </div>
    </div>
  </div>

  <!-- Contenedor de notificaciones -->
  <div id="notifications-container" style="position: fixed; top: 20px; right: 20px; z-index: 9999; max-width: 400px;"></div>

  <script type="application/json" id="products-bootstrap" set:html={JSON.stringify(payload)}></script>
  <script is:inline>
    const bootstrapNode = document.getElementById("products-bootstrap");
    if (bootstrapNode) {
      const bootstrap = JSON.parse(bootstrapNode.textContent || "{\"products\":[],\"categories\":[],\"cloudinaryConfigured\":false}");
      let products = [...(bootstrap.products || [])];
      let categories = [...(bootstrap.categories || [])];
      let selectedProductId = products[0]?.id ?? null;
      let productQuery = "";

      const productList = document.getElementById("product-list");
      const productCountNote = document.getElementById("product-count-note");
      const productFeedback = document.getElementById("product-feedback");
      const productForm = document.getElementById("product-form");
      const categorySelect = document.getElementById("category");
      const productSearch = document.getElementById("product-search");
      const productEditorTitle = document.getElementById("product-editor-title");
      const deleteProductButton = document.getElementById("delete-product-button");
      const coverPreview = document.getElementById("cover-preview");
      const galleryPreview = document.getElementById("gallery-preview");
      const productPreviewMedia = document.getElementById("product-preview-media");
      const productPreviewTitle = document.getElementById("product-preview-title");
      const productPreviewCopy = document.getElementById("product-preview-copy");
      const productPreviewCategory = document.getElementById("product-preview-category");
      const productPreviewStatus = document.getElementById("product-preview-status");
      const productPreviewSheet = document.getElementById("product-preview-sheet");

      // Variables para el selector de imágenes
      const imageSelectorModal = document.getElementById("image-selector-modal");
      const imageSelectorGrid = document.getElementById("image-selector-grid");
      const imageSelectorFeedback = document.getElementById("image-selector-feedback");
      const imageSelectorBreadcrumbs = document.getElementById("image-selector-breadcrumbs");
      let currentImageTarget = ""; // "cover", "gallery", "seo"
      let currentImageFolder = "industriasmm";
      let availableFolders = [];
      let availableImages = [];

      const productBaseState = {
        productId: "", title: "", slug: "", category: "", excerpt: "", description: "",
        status: "draft", coverImage: "", coverAlt: "", specSheet: "", featured: false,
        price: "", show_price: false,
        gallery: "", benefits: "", measurements: "", specs: "", seoTitle: "", seoCanonical: "",
        seoDescription: "", seoImage: "", body: "",
      };

      function setFeedback(node, message, tone = "info") {
        node.textContent = message;
        node.dataset.tone = tone;
      }

      // Sistema de notificaciones
      const notificationsContainer = document.getElementById("notifications-container");

      function showNotification(message, type = "info", duration = 5000) {
        const notification = document.createElement("div");
        notification.className = `notification notification--${type}`;
        notification.style.cssText = `
          background: ${type === "success" ? "#10b981" : type === "error" ? "#ef4444" : type === "warning" ? "#f59e0b" : "#3b82f6"};
          color: white;
          padding: 12px 16px;
          border-radius: 8px;
          margin-bottom: 8px;
          box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
          font-size: 14px;
          font-weight: 500;
          display: flex;
          align-items: center;
          justify-content: space-between;
          animation: slideIn 0.3s ease-out;
          max-width: 100%;
          word-wrap: break-word;
        `;

        const messageSpan = document.createElement("span");
        messageSpan.textContent = message;
        messageSpan.style.flex = "1";

        const closeButton = document.createElement("button");
        closeButton.innerHTML = "&times;";
        closeButton.style.cssText = `
          background: none;
          border: none;
          color: white;
          font-size: 18px;
          cursor: pointer;
          margin-left: 12px;
          padding: 0;
          opacity: 0.8;
        `;
        closeButton.onclick = () => removeNotification(notification);

        notification.appendChild(messageSpan);
        notification.appendChild(closeButton);
        notificationsContainer.appendChild(notification);

        // Auto-remover después de la duración especificada
        if (duration > 0) {
          setTimeout(() => removeNotification(notification), duration);
        }

        return notification;
      }

      function removeNotification(notification) {
        if (notification && notification.parentNode) {
          notification.style.animation = "slideOut 0.3s ease-in";
          setTimeout(() => {
            if (notification.parentNode) {
              notification.parentNode.removeChild(notification);
            }
          }, 300);
        }
      }

      // Agregar estilos CSS para las animaciones
      const style = document.createElement("style");
      style.textContent = `
        @keyframes slideIn {
          from { transform: translateX(100%); opacity: 0; }
          to { transform: translateX(0); opacity: 1; }
        }
        @keyframes slideOut {
          from { transform: translateX(0); opacity: 1; }
          to { transform: translateX(100%); opacity: 0; }
        }
      `;
      document.head.appendChild(style);

      function joinLines(items) {
        return Array.isArray(items) ? items.join("\n") : "";
      }

      function specsToLines(specs) {
        return Array.isArray(specs) ? specs.map((spec) => `${spec.label}: ${spec.value}`).join("\n") : "";
      }

      function measurementsToLines(measurements) {
        return Array.isArray(measurements)
          ? measurements.map((m) => [m.name ?? "", m.width ?? "", m.height ?? "", m.depth ?? "", m.length ?? "", m.capacity ?? "", m.unit ?? ""].join(" | ")).join("\n")
          : "";
      }

      function parseLines(value) {
        return value.split("\n").map((item) => item.trim()).filter(Boolean);
      }

      function parseSpecs(value) {
        return value.split("\n").map((line) => line.trim()).filter(Boolean).map((line) => {
          const separatorIndex = line.indexOf(":");
          if (separatorIndex === -1) return { label: line, value: "" };
          return { label: line.slice(0, separatorIndex).trim(), value: line.slice(separatorIndex + 1).trim() };
        }).filter((spec) => spec.label && spec.value);
      }

      function parseMeasurements(value) {
        return value.split("\n").map((line, index) => {
          const [name = "", width = "", height = "", depth = "", length = "", capacity = "", unit = ""] = line.split("|").map((part) => part.trim());
          return { name, width, height, depth, length, capacity, unit, order: index };
        }).filter((measurement) => measurement.name);
      }

      function setFormValue(form, name, value) {
        const field = form.elements.namedItem(name);
        if (!field) return;
        if (field instanceof HTMLInputElement && field.type === "checkbox") {
          field.checked = Boolean(value);
          return;
        }
        field.value = value ?? "";
      }

      function fillCategoryOptions() {
        categorySelect.innerHTML = "";
        categories.forEach((category) => {
          const option = document.createElement("option");
          option.value = category.slug;
          option.textContent = `${category.data.title}${category.data.status === "draft" ? " (borrador)" : ""}`;
          categorySelect.appendChild(option);
        });
      }

      function buildProductState(product) {
        if (!product) return { ...productBaseState, category: categories[0]?.slug ?? "" };
        return {
          productId: String(product.id),
          title: product.data.title ?? "",
          slug: product.slug ?? "",
          category: product.data.category ?? categories[0]?.slug ?? "",
          excerpt: product.data.excerpt ?? "",
          description: product.data.description ?? "",
          status: product.data.status ?? "draft",
          coverImage: product.data.coverImage ?? "",
          coverAlt: product.data.coverAlt ?? "",
          specSheet: product.data.specSheet ?? "",
          featured: Boolean(product.data.featured),
          price: product.data.price ?? "",
          show_price: Boolean(product.data.show_price),
          gallery: joinLines(product.data.gallery),
          benefits: joinLines(product.data.benefits),
          measurements: measurementsToLines(product.data.measurements),
          specs: specsToLines(product.data.specs),
          seoTitle: product.data.seo?.title ?? "",
          seoCanonical: product.data.seo?.canonical ?? "",
          seoDescription: product.data.seo?.description ?? "",
          seoImage: product.data.seo?.image ?? "",
          body: product.body ?? "",
        };
      }

      function setPreviewBackground(node, url) {
        node.style.backgroundImage = url ? `url('${String(url).replace(/'/g, "%27")}')` : "";
      }

      function renderGalleryPreview() {
        const urls = parseLines(String(productForm.elements.namedItem("gallery")?.value ?? ""));
        if (urls.length === 0) {
          galleryPreview.innerHTML = '<div class="empty-note">Todavía no hay imágenes en la galería.</div>';
          return;
        }

        galleryPreview.innerHTML = urls.map((url, idx) => `
          <div class="gallery-thumb" style="position:relative;background-image:url('${url.replace(/'/g, "%27")}')">
            <button type="button" class="gallery-remove-btn" data-idx="${idx}" title="Eliminar imagen" style="position:absolute;top:2px;right:2px;background:rgba(0,0,0,0.6);color:#fff;border:none;border-radius:50%;width:22px;height:22px;cursor:pointer;font-size:16px;line-height:20px;display:flex;align-items:center;justify-content:center;">×</button>
          </div>
        `).join("");

        // Agregar eventos a los botones de eliminar
        galleryPreview.querySelectorAll('.gallery-remove-btn').forEach(btn => {
          btn.addEventListener('click', (e) => {
            const idx = parseInt(btn.getAttribute('data-idx'));
            urls.splice(idx, 1);
            productForm.elements.namedItem("gallery").value = urls.join("\n");
            renderGalleryPreview();
          });
        });
      }

      // Funciones para el selector de imágenes
      async function loadAvailableImages(folder = "industriasmm") {
        try {
          currentImageFolder = folder;
          imageSelectorFeedback.textContent = "Cargando contenido...";
          const response = await fetch(`/api/admin/images?folder=${encodeURIComponent(folder)}`);
          const result = await response.json();
          if (!response.ok) {
            throw new Error(result.message || "Error al cargar imágenes");
          }

          availableFolders = result.folders || [];
          availableImages = result.images || [];
          renderImageSelectorBreadcrumbs();
          renderImageSelector();
          imageSelectorFeedback.textContent = `${availableFolders.length} carpeta(s), ${availableImages.length} imagen(es) disponibles`;
        } catch (error) {
          imageSelectorFeedback.textContent = error.message;
          imageSelectorGrid.innerHTML = '<div class="empty-note">Error al cargar imágenes</div>';
        }
      }

      function renderImageSelectorBreadcrumbs() {
        const segments = String(currentImageFolder || "industriasmm").split("/").filter(Boolean);
        let path = "";
        const breadcrumbs = segments.map((segment, index) => {
          path += (index ? "/" : "") + segment;
          return `<button type=\"button\" class=\"image-selector-breadcrumb\" data-folder=\"${encodeURIComponent(path)}\" style=\"all: unset; cursor: pointer; color: var(--accent); font-weight: 700; margin-right: 0.5rem;\">${segment}</button>` + (index < segments.length - 1 ? '<span style=\"margin-right: 0.5rem;color:#999;\">/</span>' : '');
        }).join("");

        imageSelectorBreadcrumbs.innerHTML = breadcrumbs || '<span>Carpeta raíz</span>';
        imageSelectorBreadcrumbs.querySelectorAll(".image-selector-breadcrumb").forEach((button) => {
          button.addEventListener("click", () => {
            const folder = decodeURIComponent(button.getAttribute("data-folder") || "industriasmm");
            loadAvailableImages(folder);
          });
        });
      }

      function renderImageSelector() {
        if (availableFolders.length === 0 && availableImages.length === 0) {
          imageSelectorGrid.innerHTML = '<div class="empty-note">No hay carpetas ni imágenes en esta ubicación.</div>';
          return;
        }

        const foldersHtml = availableFolders.map((folder, index) => `
          <div class="image-selector-folder" data-folder="${encodeURIComponent(folder.path)}" style="cursor: pointer; border: 2px solid transparent; border-radius: 0.5rem; padding: 0.75rem; min-height: 7rem; display: grid; place-items: center; background: #f7f8f7;">
            <strong style="color: var(--accent);">📁</strong>
            <small style="display:block; margin-top:0.5rem; text-align:center; color:#334;">${folder.name}</small>
          </div>
        `).join("");

        const imagesHtml = availableImages.map((image, index) => `
          <div class="image-selector-item" data-index="${index}" style="cursor: pointer; border: 2px solid transparent; border-radius: 0.5rem; overflow: hidden; aspect-ratio: 1; background: #f0f0f0 center center / cover no-repeat; background-image: url('${image.secure_url.replace(/'/g, "%27")}'); transition: border-color 0.2s;">
            <div style="width: 100%; height: 100%; display: flex; align-items: flex-end; background: linear-gradient(transparent, rgba(0,0,0,0.7)); padding: 0.5rem; box-sizing: border-box;">
              <small style="color: white; font-size: 0.75rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">${image.public_id.split('/').pop()}</small>
            </div>
          </div>
        `).join("");

        imageSelectorGrid.innerHTML = `${foldersHtml}${imagesHtml}`;

        imageSelectorGrid.querySelectorAll('.image-selector-folder').forEach((folderItem) => {
          folderItem.addEventListener('click', () => {
            const folder = decodeURIComponent(folderItem.getAttribute('data-folder') || 'industriasmm');
            loadAvailableImages(folder);
          });
          folderItem.addEventListener('mouseenter', () => {
            folderItem.style.borderColor = 'var(--accent)';
          });
          folderItem.addEventListener('mouseleave', () => {
            folderItem.style.borderColor = 'transparent';
          });
        });

        imageSelectorGrid.querySelectorAll('.image-selector-item').forEach((item) => {
          item.addEventListener('click', () => {
            const index = parseInt(item.getAttribute('data-index'));
            const selectedImage = availableImages[index];
            selectImage(selectedImage.secure_url);
          });
          item.addEventListener('mouseenter', () => {
            item.style.borderColor = 'var(--accent)';
          });
          item.addEventListener('mouseleave', () => {
            item.style.borderColor = 'transparent';
          });
        });
      }

      function selectImage(url) {
        if (currentImageTarget === "cover") {
          productForm.elements.namedItem("coverImage").value = url;
          updateProductPreview();
          setFeedback(productFeedback, "Imagen de portada seleccionada.");
          showNotification("Imagen de portada seleccionada.", "success");
        } else if (currentImageTarget === "gallery") {
          const current = productForm.elements.namedItem("gallery").value.trim();
          const urls = current ? current.split('\n') : [];
          urls.push(url);
          productForm.elements.namedItem("gallery").value = urls.join('\n');
          renderGalleryPreview();
          setFeedback(productFeedback, "Imagen agregada a la galería.");
          showNotification("Imagen agregada a la galería.", "success");
        } else if (currentImageTarget === "seo") {
          productForm.elements.namedItem("seoImage").value = url;
          setFeedback(productFeedback, "Imagen SEO seleccionada.");
          showNotification("Imagen SEO seleccionada.", "success");
        }
        closeImageSelector();
      }

      function openImageSelector(target) {
        currentImageTarget = target;
        imageSelectorModal.style.display = "flex";
        loadAvailableImages("industriasmm");
      }

      function closeImageSelector() {
        imageSelectorModal.style.display = "none";
        currentImageTarget = "";
      }

      function updateProductPreview(product) {
        productPreviewTitle.textContent = product?.data?.title ?? productForm.elements.namedItem("title")?.value ?? "Nuevo producto";
        productPreviewCopy.textContent = product?.data?.description ?? productForm.elements.namedItem("description")?.value ?? "Aquí verás una síntesis del registro activo.";
        productPreviewCategory.textContent = product?.data?.category ?? productForm.elements.namedItem("category")?.value ?? "-";
        const status = product?.data?.status ?? productForm.elements.namedItem("status")?.value ?? "draft";
        productPreviewStatus.textContent = status === "published" ? "Publicado" : "Borrador";
        const specSheet = product?.data?.specSheet ?? productForm.elements.namedItem("specSheet")?.value ?? "";
        productPreviewSheet.textContent = specSheet ? "Sí" : "No";
        const image = product?.data?.coverImage ?? productForm.elements.namedItem("coverImage")?.value ?? "";
        setPreviewBackground(productPreviewMedia, image);
        setPreviewBackground(coverPreview, image);
        renderGalleryPreview();
      }

      function getFilteredProducts() {
        const query = productQuery.trim().toLowerCase();
        if (!query) return products;
        return products.filter((product) => {
          const haystack = [product.data.title, product.slug, product.data.category, product.data.status].join(" ").toLowerCase();
          return haystack.includes(query);
        });
      }

      function renderProductList() {
        const filtered = getFilteredProducts();
        productCountNote.textContent = filtered.length === products.length
          ? `${products.length} producto(s) en Postgres.`
          : `${filtered.length} resultado(s) de ${products.length} producto(s).`;

        if (filtered.length === 0) {
          productList.innerHTML = '<div class="empty-note">No hay productos que coincidan con la búsqueda.</div>';
          return;
        }

        productList.innerHTML = "";
        filtered.forEach((product) => {
          const button = document.createElement("button");
          button.type = "button";
          button.className = `record-card${product.id === selectedProductId ? " is-active" : ""}`;
          const image = product.data.coverImage ? `style="background-image:url('${product.data.coverImage.replace(/'/g, "%27")}')"` : "";
          button.innerHTML = `
            <div class="record-thumb" ${image}></div>
            <div class="record-main">
              <strong>${product.data.title}</strong>
              <small>${product.slug}</small>
            </div>
            <div class="record-side">
              <strong>${product.data.category}</strong>
              <small>${product.data.featured ? "Destacado" : "Estándar"}</small>
            </div>
            <div class="record-price">
              ${typeof product.data.price === 'number' ? product.data.price : '-'}
            </div>
            <div>
              <span class="status-pill ${product.data.status === "published" ? "status-pill--published" : "status-pill--draft"}">${product.data.status === "published" ? "Publicado" : "Borrador"}</span>
            </div>
          `;
          button.addEventListener("click", () => {
            selectedProductId = product.id;
            hydrateProductEditor();
          });
          productList.appendChild(button);
        });
      }

      function hydrateProductEditor() {
        const selected = products.find((item) => item.id === selectedProductId);
        const state = buildProductState(selected);
        Object.entries(state).forEach(([name, value]) => setFormValue(productForm, name, value));
        productEditorTitle.textContent = selected ? `Editar producto: ${selected.data.title}` : "Nuevo producto";
        deleteProductButton.disabled = !selected;
        renderProductList();
        updateProductPreview(selected);
        // Oculta el listado si hay producto seleccionado y ajusta el grid y el detalle
        const aside = document.getElementById("product-list-aside");
        const backBtn = document.getElementById("back-to-list");
        const grid = document.getElementById("workspace-grid");
        const detail = document.getElementById("product-detail-section");
        if (selected) {
          aside.style.display = "none";
          backBtn.style.display = "inline-block";
          grid.classList.add("single-column");
          detail.classList.add("full-width");
        } else {
          aside.style.display = "";
          backBtn.style.display = "none";
          grid.classList.remove("single-column");
          detail.classList.remove("full-width");
        }
      }

      function getProductPayload() {
        const formData = new FormData(productForm);
        return {
          slug: String(formData.get("slug") ?? ""),
          title: String(formData.get("title") ?? ""),
          category: String(formData.get("category") ?? ""),
          excerpt: String(formData.get("excerpt") ?? ""),
          description: String(formData.get("description") ?? ""),
          status: String(formData.get("status") ?? "draft"),
          featured: formData.get("featured") === "on",
          price: formData.get("price") ? Number(formData.get("price")) : undefined,
          show_price: formData.get("show_price") === "on",
          coverImage: String(formData.get("coverImage") ?? ""),
          coverAlt: String(formData.get("coverAlt") ?? ""),
          specSheet: String(formData.get("specSheet") ?? ""),
          gallery: parseLines(String(formData.get("gallery") ?? "")),
          benefits: parseLines(String(formData.get("benefits") ?? "")),
          measurements: parseMeasurements(String(formData.get("measurements") ?? "")),
          specs: parseSpecs(String(formData.get("specs") ?? "")),
          seo: {
            title: String(formData.get("seoTitle") ?? ""),
            canonical: String(formData.get("seoCanonical") ?? ""),
            description: String(formData.get("seoDescription") ?? ""),
            image: String(formData.get("seoImage") ?? ""),
          },
          body: String(formData.get("body") ?? ""),
        };
      }

      async function syncProducts() {
        const response = await fetch("/api/admin/products");
        const result = await response.json();
        if (response.ok) {
          products = result.products ?? [];
        }
      }

      async function uploadFiles(files, kind, folder = "industriasmm") {
        const urls = [];
        for (const file of files) {
          const data = new FormData();
          data.append("file", file);
          data.append("kind", kind);
          data.append("folder", folder);
          const response = await fetch("/api/admin/uploads", { method: "POST", body: data });
          const result = await response.json();
          if (!response.ok) {
            throw new Error(result.message ?? "No fue posible subir el archivo.");
          }
          urls.push(result.url);
        }
        return urls;
      }

      function bindEditorTabs() {
        document.querySelectorAll("[data-editor-tabs]").forEach((group) => {
          const links = [...group.querySelectorAll(".editor-tab")];
          const activate = (activeLink) => {
            links.forEach((link) => link.classList.toggle("is-active", link === activeLink));
          };

          links.forEach((link) => {
            link.addEventListener("click", (event) => {
              const target = document.querySelector(link.getAttribute("href"));
              if (!target) return;
              event.preventDefault();
              activate(link);
              target.scrollIntoView({ behavior: "smooth", block: "start" });
            });
          });
        });
      }

      fillCategoryOptions();
      hydrateProductEditor();
      bindEditorTabs();

      productSearch.addEventListener("input", () => {
        productQuery = productSearch.value;
        renderProductList();
      });

      document.getElementById("new-product-button").addEventListener("click", () => {
        selectedProductId = null;
        hydrateProductEditor();
        setFeedback(productFeedback, "Formulario listo para un producto nuevo.");
      });

      document.getElementById("reset-product-button").addEventListener("click", () => {
        hydrateProductEditor();
        setFeedback(productFeedback, "Se restauraron los datos visibles del editor.");
      });

      ["title", "description", "category", "status", "coverImage", "gallery", "specSheet"].forEach((name) => {
        productForm.elements.namedItem(name)?.addEventListener("input", () => updateProductPreview());
        productForm.elements.namedItem(name)?.addEventListener("change", () => updateProductPreview());
      });

      document.getElementById("upload-cover-button").addEventListener("click", async () => {
        const input = document.getElementById("cover-file");
        if (!bootstrap.cloudinaryConfigured) {
          setFeedback(productFeedback, "Cloudinary no está configurado.", "error");
          showNotification("Cloudinary no está configurado.", "error");
          return;
        }
        if (!input.files?.length) {
          setFeedback(productFeedback, "Selecciona una imagen de portada.", "error");
          showNotification("Selecciona una imagen de portada.", "warning");
          return;
        }
        setFeedback(productFeedback, "Subiendo portada...");
        showNotification("Subiendo imagen de portada...", "info");
        try {
          const [url] = await uploadFiles([input.files[0]], "image");
          productForm.elements.namedItem("coverImage").value = url;
          updateProductPreview();
          setFeedback(productFeedback, "Portada subida correctamente.");
          showNotification("Imagen de portada subida correctamente.", "success");
          input.value = "";
        } catch (error) {
          setFeedback(productFeedback, error.message, "error");
          showNotification(error.message, "error");
        }
      });

      document.getElementById("upload-gallery-button").addEventListener("click", async () => {
        const input = document.getElementById("gallery-files");
        if (!bootstrap.cloudinaryConfigured) {
          setFeedback(productFeedback, "Cloudinary no está configurado.", "error");
          showNotification("Cloudinary no está configurado.", "error");
          return;
        }
        if (!input.files?.length) {
          setFeedback(productFeedback, "Selecciona una o más imágenes para la galería.", "error");
          showNotification("Selecciona una o más imágenes para la galería.", "warning");
          return;
        }
        setFeedback(productFeedback, "Subiendo imágenes de galería...");
        showNotification(`Subiendo ${input.files.length} imagen(es) a la galería...`, "info");
        try {
          const urls = await uploadFiles([...input.files], "image");
          const current = productForm.elements.namedItem("gallery").value.trim();
          productForm.elements.namedItem("gallery").value = [current, ...urls].filter(Boolean).join("\n");
          renderGalleryPreview();
          setFeedback(productFeedback, "Galería actualizada.");
          showNotification(`${urls.length} imagen(es) agregada(s) a la galería.`, "success");
          input.value = "";
        } catch (error) {
          setFeedback(productFeedback, error.message, "error");
          showNotification(error.message, "error");
        }
      });

      document.getElementById("upload-sheet-button").addEventListener("click", async () => {
        const input = document.getElementById("spec-sheet-file");
        if (!bootstrap.cloudinaryConfigured) {
          setFeedback(productFeedback, "Cloudinary no está configurado.", "error");
          showNotification("Cloudinary no está configurado.", "error");
          return;
        }
        if (!input.files?.length) {
          setFeedback(productFeedback, "Selecciona un PDF para la ficha técnica.", "error");
          showNotification("Selecciona un PDF para la ficha técnica.", "warning");
          return;
        }
        setFeedback(productFeedback, "Subiendo ficha técnica...");
        showNotification("Subiendo ficha técnica PDF...", "info");
        try {
          const [url] = await uploadFiles([input.files[0]], "raw");
          productForm.elements.namedItem("specSheet").value = url;
          updateProductPreview();
          setFeedback(productFeedback, "Ficha técnica subida correctamente.");
          showNotification("Ficha técnica subida correctamente.", "success");
          input.value = "";
        } catch (error) {
          setFeedback(productFeedback, error.message, "error");
          showNotification(error.message, "error");
        }
      });

      document.getElementById("upload-seo-button").addEventListener("click", async () => {
        const input = document.getElementById("seo-image-file");
        if (!bootstrap.cloudinaryConfigured) {
          setFeedback(productFeedback, "Cloudinary no está configurado.", "error");
          showNotification("Cloudinary no está configurado.", "error");
          return;
        }
        if (!input.files?.length) {
          setFeedback(productFeedback, "Selecciona una imagen SEO.", "error");
          showNotification("Selecciona una imagen SEO.", "warning");
          return;
        }
        setFeedback(productFeedback, "Subiendo imagen SEO...");
        showNotification("Subiendo imagen SEO...", "info");
        try {
          const [url] = await uploadFiles([input.files[0]], "image");
          productForm.elements.namedItem("seoImage").value = url;
          setFeedback(productFeedback, "Imagen SEO subida correctamente.");
          showNotification("Imagen SEO subida correctamente.", "success");
          input.value = "";
        } catch (error) {
          setFeedback(productFeedback, error.message, "error");
          showNotification(error.message, "error");
        }
      });

      // Event listeners para seleccionar imágenes existentes
      document.getElementById("select-cover-button").addEventListener("click", () => {
        openImageSelector("cover");
      });

      document.getElementById("select-gallery-button").addEventListener("click", () => {
        openImageSelector("gallery");
      });

      document.getElementById("select-seo-button").addEventListener("click", () => {
        openImageSelector("seo");
      });

      document.getElementById("upload-to-folder-button").addEventListener("click", () => {
        const input = document.getElementById("upload-to-folder-file");
        input.click();
      });

      document.getElementById("upload-to-folder-file").addEventListener("change", async () => {
        const input = document.getElementById("upload-to-folder-file");
        if (!bootstrap.cloudinaryConfigured) {
          setFeedback(imageSelectorFeedback, "Cloudinary no está configurado.", "error");
          showNotification("Cloudinary no está configurado.", "error");
          return;
        }
        if (!input.files?.length) {
          setFeedback(imageSelectorFeedback, "Selecciona una o más imágenes para subir.", "error");
          showNotification("Selecciona una o más imágenes para subir.", "warning");
          return;
        }
        setFeedback(imageSelectorFeedback, "Subiendo imágenes...");
        showNotification(`Subiendo ${input.files.length} imagen(es) a la carpeta ${currentImageFolder}...`, "info");
        try {
          await uploadFiles([...input.files], "image", currentImageFolder);
          setFeedback(imageSelectorFeedback, "Imágenes subidas correctamente. Recargando...");
          showNotification(`${input.files.length} imagen(es) subida(s) correctamente.`, "success");
          await loadAvailableImages(currentImageFolder);
        } catch (error) {
          setFeedback(imageSelectorFeedback, error.message, "error");
          showNotification(error.message, "error");
        }
        input.value = "";
      });

      document.getElementById("close-image-selector").addEventListener("click", closeImageSelector);
      document.getElementById("cancel-image-selector").addEventListener("click", closeImageSelector);

      // Cerrar modal al hacer clic fuera
      imageSelectorModal.addEventListener("click", (e) => {
        if (e.target === imageSelectorModal) {
          closeImageSelector();
        }
      });

      productForm.addEventListener("submit", async (event) => {
        event.preventDefault();
        const saveButton = document.getElementById("save-product-button");
        saveButton.disabled = true;
        setFeedback(productFeedback, "Guardando producto...");
        showNotification("Guardando producto...", "info");
        const id = Number(productForm.elements.namedItem("productId")?.value || 0);
        const isEditing = Number.isInteger(id) && id > 0;
        const response = await fetch(isEditing ? `/api/admin/products/${id}` : "/api/admin/products", {
          method: isEditing ? "PUT" : "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(getProductPayload()),
        });
        const result = await response.json();
        if (!response.ok) {
          saveButton.disabled = false;
          setFeedback(productFeedback, result.message ?? "No fue posible guardar el producto.", "error");
          showNotification(result.message ?? "No fue posible guardar el producto.", "error");
          return;
        }
        await syncProducts();
        selectedProductId = result.product?.id ?? selectedProductId;
        hydrateProductEditor();
        setFeedback(productFeedback, "Producto guardado correctamente.");
        showNotification(isEditing ? "Producto actualizado correctamente." : "Producto creado correctamente.", "success");
        saveButton.disabled = false;
      });

      deleteProductButton.addEventListener("click", async () => {
        const id = Number(productForm.elements.namedItem("productId")?.value || 0);
        if (!id || !window.confirm("¿Seguro que quieres eliminar este producto?")) return;
        setFeedback(productFeedback, "Eliminando producto...");
        showNotification("Eliminando producto...", "warning");
        const response = await fetch(`/api/admin/products/${id}`, { method: "DELETE" });
        const result = await response.json();
        if (!response.ok) {
          setFeedback(productFeedback, result.message ?? "No fue posible eliminar el producto.", "error");
          showNotification(result.message ?? "No fue posible eliminar el producto.", "error");
          return;
        }
        await syncProducts();
        selectedProductId = products[0]?.id ?? null;
        hydrateProductEditor();
        setFeedback(productFeedback, "Producto eliminado.");
        showNotification("Producto eliminado correctamente.", "success");
      });
      // Botón para volver al listado
      document.getElementById("back-to-list").addEventListener("click", () => {
        selectedProductId = null;
        hydrateProductEditor();
      });
    }
  </script>
</AdminLayout>
