export const prerender = false;
---
import ProductCategoryGrid from "@/components/products/ProductCategoryGrid.astro";
import ProductGrid from "@/components/products/ProductGrid.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import Container from "@/components/ui/Container.astro";
import { getPublishedProducts } from "@/lib/content/products";
import { getProductCategoryMap, getProductCategorySections } from "@/lib/content/productCategories";
import { buildPageSeo } from "@/lib/seo/metadata";
import PageLayout from "@/layouts/PageLayout.astro";

const [products, sections, categoryMap] = await Promise.all([
  getPublishedProducts(),
  getProductCategorySections(),
  getProductCategoryMap(),
]);
const categoryLabels = Object.fromEntries(
  Object.entries(categoryMap).map(([slug, category]) => [slug, category.data.title]),
);
---
<PageLayout
  title="Productos industriales"
  intro="Catálogo organizado por categorías para navegar mejor cada línea de productos."
  seo={buildPageSeo({
    title: "Productos industriales | Industrias MM",
    description: "Catálogo de productos metálicos para industria, comercio y logística.",
    canonical: "/productos",
  })}
  breadcrumbs={[{ name: "Productos", url: "/productos" }]}
>
  <section class="section-padding">
    <Container>
      <div class="flow">
        <SectionHeading
          eyebrow="Categorias"
          title="Explora el catálogo por línea de producto"
          description="Cada categoría agrupa soluciones relacionadas para hacer más clara la navegación y el mantenimiento del contenido."
        />
        <ProductCategoryGrid sections={sections} />
      </div>
    </Container>
  </section>
  <section class="section-padding section-alt">
    <Container>
      <div class="flow">
        <SectionHeading
          eyebrow="Todos los productos"
          title="Vista general del catálogo"
          description="También puedes revisar el inventario completo de productos publicados."
        />
        <ProductGrid products={products} categoryLabels={categoryLabels} />
      </div>
    </Container>
  </section>
</PageLayout>
