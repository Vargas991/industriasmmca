---
import EmptyState from "@/components/shared/EmptyState.astro";
import ProductGrid from "@/components/products/ProductGrid.astro";
import Container from "@/components/ui/Container.astro";
import { getProductCategoryBySlug } from "@/lib/content/productCategories";
import { getProductsByCategory } from "@/lib/content/products";
import { buildPageSeo } from "@/lib/seo/metadata";
import PageLayout from "@/layouts/PageLayout.astro";

const { slug } = Astro.params;
const [category, products] = await Promise.all([
  getProductCategoryBySlug(slug!),
  getProductsByCategory(slug!),
]);

if (!category) {
  throw new Error(`Categoria no encontrada: ${slug}`);
}
---
<PageLayout
  title={category.data.title}
  intro={category.data.description}
  seo={buildPageSeo({
    title: category.data.seo.title,
    description: category.data.seo.description,
    canonical: category.data.seo.canonical ?? `/productos/categoria/${slug}`,
    image: category.data.seo.image ?? category.data.coverImage,
  })}
  breadcrumbs={[
    { name: "Productos", url: "/productos" },
    { name: category.data.title, url: `/productos/categoria/${slug}` },
  ]}
>
  <section class="section-padding">
    <Container>
      {products.length > 0 ? (
        <ProductGrid products={products} categoryLabels={{ [category.slug]: category.data.title }} />
      ) : (
        <EmptyState title="Sin productos publicados" description="Esta categoria aun no tiene elementos visibles." />
      )}
    </Container>
  </section>
</PageLayout>
