---
import type { ProductMeasurement } from "@/types/product";

interface Props {
  specs?: Array<{
    label: string;
    value: string;
  }>;
  measurements?: ProductMeasurement[];
  specSheet?: string;
}

const { specs, measurements = [], specSheet } = Astro.props;
---
{((specs && specs.length > 0) || measurements.length > 0) && (
  <section class="product-spec-card">
    <div class="product-spec-card__header flow">
      <p class="eyebrow">Ficha técnica</p>
      <h2>Especificaciones</h2>
    </div>

    {measurements.length > 0 && (
      <div class="product-measurements flow">
        <h3>Medidas disponibles</h3>
        <div class="product-measurement-table-shell">
          <table class="product-measurement-table">
            <thead>
              <tr>
                <th>Modelo</th>
                <th>Ancho</th>
                <th>Alto</th>
                <th>Prof.</th>
                <th>Largo</th>
                <th>Capacidad</th>
              </tr>
            </thead>
            <tbody>
              {measurements.map((measurement) => (
                <tr>
                  <th scope="row">{measurement.name}</th>
                  <td>{measurement.width ?? "-"}</td>
                  <td>{measurement.height ?? "-"}</td>
                  <td>{measurement.depth ?? "-"}</td>
                  <td>{measurement.length ?? "-"}</td>
                  <td>
                    {measurement.capacity
                      ? `${measurement.capacity}${measurement.unit ? ` ${measurement.unit}` : ""}`
                      : "-"}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    )}

    {specs && specs.length > 0 && (
      <dl class="product-spec-list">
        {specs.map((spec) => (
          <div class="product-spec-row">
            <dt>{spec.label}</dt>
            <dd>{spec.value}</dd>
          </div>
        ))}
      </dl>
    )}

    {specSheet && (
      <a class="product-spec-download" href={specSheet}>
        Descargar ficha técnica
      </a>
    )}
  </section>
)}
