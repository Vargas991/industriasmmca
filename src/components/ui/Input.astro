---
interface Props {
  id: string;
  label: string;
  name: string;
  type?:
    | "text"
    | "email"
    | "tel"
    | "number"
    | "password"
    | "search"
    | "url";
  required?: boolean;
}

const { id, label, name, type = "text", required = false } = Astro.props;
---
<label class="field" for={id}>
  <span>{label}</span>
  <input id={id} name={name} type={type} required={required} />
</label>
