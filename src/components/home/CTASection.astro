---
import Button from "@/components/ui/Button.astro";
import Container from "@/components/ui/Container.astro";
---
<section class="cta-section">
  <Container>
    <div class="cta-box">
      <div class="flow">
        <p class="eyebrow">Cotizacion</p>
        <h2>Conversemos sobre tu proyecto</h2>
        <p>Podemos ayudarte a definir una solución práctica, durable y alineada con tu operación.</p>
      </div>
      <Button href="/contacto">Hablar con un asesor</Button>
    </div>
  </Container>
</section>
