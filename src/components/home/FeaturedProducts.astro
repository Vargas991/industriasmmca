---
import Button from "@/components/ui/Button.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import Container from "@/components/ui/Container.astro";
import { slugToTitle } from "@/lib/utils/strings";
import type { ProductEntry } from "@/types/product";

interface Props {
  products: ProductEntry[];
}

const { products } = Astro.props;
const paletteClasses = [
  "product-showcase-card--mint",
  "product-showcase-card--powder",
  "product-showcase-card--lilac",
  "product-showcase-card--sand",
];
---
<section class="section-padding product-showcase-section">
  <Container>
    <div class="product-showcase-shell">
      <div class="product-showcase-heading">
        <SectionHeading
          eyebrow="Productos"
          title="Productos destacados"
          description="Una selección de soluciones listas para almacenamiento, retail y operación comercial."
        />
      </div>

      <div class="product-showcase-stage">
        <div class="product-showcase-visual" aria-hidden="true"></div>

        <div class="product-showcase-slider" data-product-slider>
          <div class="product-showcase-track" data-product-track>
          {products.map((product, index) => (
              <article class={`product-showcase-card ${paletteClasses[index % paletteClasses.length]}`}>
              <a class="product-showcase-link" href={`/productos/${product.slug}`}>
                <img
                  class="product-showcase-image"
                  src={product.data.coverImage}
                  alt={product.data.coverAlt}
                  loading="lazy"
                />
                <div class="flow">
                  <p class="eyebrow">{slugToTitle(product.data.category)}</p>
                  <h3>{product.data.title}</h3>
                  <p>{product.data.excerpt}</p>
                </div>
              </a>
            </article>
          ))}
          </div>
        </div>
      </div>

      <div class="product-showcase-footer">
        <div class="product-showcase-controls" aria-label="Controles de productos destacados">
          <button class="product-showcase-control" type="button" data-product-prev aria-label="Producto anterior">
            <span aria-hidden="true">&lsaquo;</span>
          </button>
          <div class="product-showcase-rail" data-product-progress>
            <span class="product-showcase-rail-fill" data-product-progress-fill></span>
          </div>
          <button class="product-showcase-control" type="button" data-product-next aria-label="Producto siguiente">
            <span aria-hidden="true">&rsaquo;</span>
          </button>
        </div>
        <Button href="/productos">Explorar catálogo</Button>
      </div>
    </div>
  </Container>
  <script>
    import "@/scripts/product-showcase-slider";
  </script>
</section>
