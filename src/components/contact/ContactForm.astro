---
import Button from "@/components/ui/Button.astro";
import { siteConfig } from "@/config/site";
import Input from "@/components/ui/Input.astro";
import Textarea from "@/components/ui/Textarea.astro";
---
<form id="contact-form" class="contact-form flow" method="post" action="/api/contact">
  <p>
    Tambien puedes escribirnos a <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>.
  </p>
  <Input id="name" name="name" label="Nombre" required />
  <Input id="email" name="email" label="Correo" type="email" required />
  <Input id="phone" name="phone" label="Telefono" />
  <Textarea id="message" name="message" label="Mensaje" required />
  <div id="form-status" class="contact-form-status" aria-live="polite"></div>
  <Button type="submit">Enviar solicitud</Button>
</form>

<div id="success-modal" class="contact-success-modal" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="success-modal-title">
  <div class="contact-success-modal__content">
    <button id="close-success-modal" type="button" class="contact-success-modal__close" aria-label="Cerrar modal">×</button>
    <div class="contact-success-modal__icon">✓</div>
    <h2 id="success-modal-title">Correo enviado</h2>
    <p>Tu mensaje fue enviado correctamente. Pronto nos pondremos en contacto contigo. Para mayor rapidez, puedes contactarnos via whatsapp al <a href={`https://api.whatsapp.com/send/?phone=5804247011430&text&type=phone_number&app_absent=0`}><strong>+{siteConfig.whatsappNumber}</strong></a>.</p>
    <button id="success-modal-button" type="button" class="contact-success-modal__button">Aceptar</button>
  </div>
</div>

<script type="module">
  const form = document.querySelector('#contact-form');
  const status = document.querySelector('#form-status');
  const modal = document.querySelector('#success-modal');
  const closeModalButton = document.querySelector('#close-success-modal');
  const acceptButton = document.querySelector('#success-modal-button');

  const openModal = () => {
    if (!modal) return;
    modal.style.display = 'flex';
    modal.setAttribute('aria-hidden', 'false');
    closeModalButton?.focus();
  };

  const closeModal = () => {
    if (!modal) return;
    modal.style.display = 'none';
    modal.setAttribute('aria-hidden', 'true');
  };

  if (form && status) {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      status.textContent = 'Enviando mensaje...';
      status.className = 'contact-form-status contact-form-status--pending';

      const formData = new FormData(form);

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: formData,
        });

        const result = await response.json();

        if (!response.ok || !result.ok) {
          throw new Error(result.errors ? result.errors.join(', ') : result.message || 'Error al enviar el formulario.');
        }

        status.textContent = 'Correo enviado correctamente. Gracias por contactarnos.';
        status.className = 'contact-form-status contact-form-status--success';
        form.reset();
        openModal();
      } catch (error) {
        const message = error?.message || 'Error al enviar el correo. Intenta de nuevo.';
        status.textContent = message;
        status.className = 'contact-form-status contact-form-status--error';
        console.error(error);
      }
    });
  }

  closeModalButton?.addEventListener('click', closeModal);
  acceptButton?.addEventListener('click', closeModal);

  modal?.addEventListener('click', (event) => {
    if (event.target === modal) {
      closeModal();
    }
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && modal && modal.getAttribute('aria-hidden') === 'false') {
      closeModal();
    }
  });
</script>

<style>
  .contact-success-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.55);
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }

  .contact-success-modal__content {
    width: min(100%, 420px);
    background: white;
    border-radius: 1rem;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
    padding: 2rem;
    text-align: center;
  }

  .contact-success-modal__close {
    position: absolute;
    right: 1rem;
    top: 1rem;
    background: transparent;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: #333;
  }

  .contact-success-modal__icon {
    width: 3rem;
    height: 3rem;
    margin: 0 auto 1rem;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: #22c55e;
    color: white;
    font-size: 1.7rem;
  }

  .contact-success-modal h2 {
    margin: 0 0 0.75rem;
    font-size: 1.5rem;
  }

  .contact-success-modal p {
    margin: 0 0 1.5rem;
    line-height: 1.6;
    color: #555;
  }

  .contact-success-modal__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.9rem 1.5rem;
    border: none;
    border-radius: 999px;
    background: #0f766e;
    color: white;
    font-weight: 600;
    cursor: pointer;
  }
</style>
